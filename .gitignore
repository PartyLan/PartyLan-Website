# .gitignore lists files Git should leave out of commits. Generated copies of
# content images are excluded because build.py recreates them in
# dist/content/images/ from the authoritative originals in content/images/.
# The legacy assets path remains generated for the existing demo-testimonial
# file, but new content must use /content/images/.
dist/assets/images/
dist/content/images/

# Python creates these local bytecode caches while running the build and tests.
__pycache__/
*.py[cod]
